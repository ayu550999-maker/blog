---
import PostList from "@/components/PostList.astro";
import TagPill from "@/components/TagPill.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/data/site";
import { sitePath } from "@/utils/paths";
import { getAllTags, getPublishedPosts } from "@/utils/posts";

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 5);
const tags = getAllTags(posts);
---

<BaseLayout title={siteConfig.name} description={siteConfig.description}>
  <section class="hero">
    <p class="eyebrow">个人博客</p>
    <h1>{siteConfig.name}</h1>
    <p>{siteConfig.description}</p>
    <div class="hero__actions">
      <a class="button" href={sitePath("/blog")}>阅读文章</a>
      <a class="button button--ghost" href={sitePath("/about")}>了解我</a>
    </div>
  </section>

  <section class="section">
    <div class="section__heading">
      <h2>最新文章</h2>
      <a href={sitePath("/blog")}>全部文章</a>
    </div>
    <PostList posts={latestPosts} />
  </section>

  {
    tags.length > 0 && (
      <section class="section">
        <div class="section__heading">
          <h2>标签</h2>
        </div>
        <div class="tag-row">
          {tags.map((tag) => (
            <TagPill tag={tag.name} count={tag.count} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
