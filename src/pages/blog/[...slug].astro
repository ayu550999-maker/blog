---
import PostLayout from "@/layouts/PostLayout.astro";
import { getLocalVisiblePosts, getPublishedPosts } from "@/utils/posts";
import { render } from "astro:content";

export async function getStaticPaths() {
  const posts = import.meta.env.DEV ? await getLocalVisiblePosts() : await getPublishedPosts();

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      previous: posts[index + 1] ?? null,
      next: posts[index - 1] ?? null
    }
  }));
}

const { post, previous, next } = Astro.props;
const { Content } = await render(post);
---

<PostLayout post={post} previous={previous} next={next}>
  <Content />
</PostLayout>
