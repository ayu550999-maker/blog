---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { sitePath } from "@/utils/paths";
---

<BaseLayout title="页面未找到" description="这个页面不存在。">
  <section class="page-header">
    <p class="eyebrow">404</p>
    <h1>页面未找到</h1>
    <p>你访问的页面不存在，可能已经移动或删除。</p>
    <p><a class="button" href={sitePath("/")}>回到首页</a></p>
  </section>
</BaseLayout>
