---
import { siteConfig } from "@/data/site";
import { routePath, sitePath } from "@/utils/paths";

const currentPath = routePath(Astro.url.pathname);
---

<header class="site-header">
  <a class="site-title" href={sitePath("/")}>{siteConfig.name}</a>
  <nav aria-label="主导航">
    {
      siteConfig.nav.map((item) => {
        const isActive = item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
        return (
          <a href={sitePath(item.href)} aria-current={isActive ? "page" : undefined}>
            {item.label}
          </a>
        );
      })
    }
  </nav>
</header>
